{
  "_comment": "Multi-account / per-category JSON shape for reference. Do NOT copy over .mcp.json — that file is now committed and must never contain a real token (its secrets stay ${VAR} env placeholders). Put real tokens in your user scope instead (`claude mcp add -s user ...` per references/installation.md) or in env vars. One connection per category binary you need (keeps context lean) and one per Hostinger account. Get the API token from hPanel. Upstream states Node.js v24+ (verified working on Node 22).",
  "mcpServers": {
    "hostinger-acctA-vps": {
      "type": "stdio",
      "command": "hostinger-vps-mcp",
      "env": { "HOSTINGER_API_TOKEN": "ACCT_A_TOKEN" }
    },
    "hostinger-acctA-dns": {
      "type": "stdio",
      "command": "hostinger-dns-mcp",
      "env": { "HOSTINGER_API_TOKEN": "ACCT_A_TOKEN" }
    },
    "hostinger-acctB-vps": {
      "type": "stdio",
      "command": "hostinger-vps-mcp",
      "env": { "HOSTINGER_API_TOKEN": "ACCT_B_TOKEN" }
    }
  }
}
